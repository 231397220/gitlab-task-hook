# gitlab-task-hook 规则配置示例
#
# 此文件存储在 Nacos 中（namespace: dev, group: GITLAB_HOOK, dataId: gitlab-task-hook.yaml）
# config-sync 服务从 Nacos 拉取此配置，缓存到本地
# hook 执行时读取本地缓存，不访问 Nacos
#
# 修改此配置后，在 Nacos 控制台发布，下一次 git push 自动生效

version: "1.0"

# 全局开关
# true：启用所有校验规则
# false：跳过所有规则，所有 push 都通过
enabled: true

mode:
  # 默认校验模式
  # enforce：违规时拒绝 push（exit 1）
  # warn：违规时输出提示但放行（exit 0）
  # 可通过环境变量 HOOK_MODE=warn 临时覆盖（运维应急）
  default: "enforce"

rules:
  # ─── root 用户跳过所有校验 ────────────────────────────
  root_bypass:
    enabled: true
    usernames:
      - "root"

  # ─── 禁止强推（non fast-forward / rewrite history）───
  # 检测本次 push 是否改写了历史提交
  non_fast_forward:
    enabled: true

  # ─── 受保护分支禁止直接 push ──────────────────────────
  # 命中 branch_regex 的分支，只允许通过 web（MR/Web 合并）
  # HTTP / SSH / 直接 push 的请求会被拒绝
  deny_direct_push:
    enabled: true
    # 匹配受保护分支的正则
    # 示例：master、sit_*、uat_* 分支
    branch_regex: "(?i)^refs/heads/(master|sit_.*|uat_.*)$"
    # 允许的协议来源
    allow_protocols:
      - "web"
    # 拒绝的协议来源
    deny_protocols:
      - "http"
      - "ssh"
      - ""  # GL_PROTOCOL 为空时视为直接 push

  # ─── GL_PROTOCOL=web 时跳过后续 push 类校验 ──────────
  # 适用于 GitLab Merge Request 合并、Web IDE 提交场景
  # 命中后会跳过：提交人一致性校验、任务 ID 校验等
  web_bypass_push_checks:
    enabled: true
    protocols:
      - "web"

  # ─── 提交人 email 前缀必须与 GL_USERNAME 一致 ────────
  # 确保代码提交者的真实身份与 push 操作者一致
  committer_match_push_user:
    enabled: true
    # 比较策略：email_prefix
    # 取 commit author/committer email 的 @ 前缀，与 GL_USERNAME 比较
    # 例如：user@example.com -> user（与 GL_USERNAME 比较）
    compare_strategy: "email_prefix"
    # merge commit 是否跳过此校验
    # true：merge commit 不检查提交人
    # false：merge commit 也需要满足提交人一致性
    skip_merge_commit: true
    # 比较时是否忽略大小写
    case_insensitive: true

  # ─── 指定分支 commit subject 必须含任务号 ─────────────
  # 在 feature / dev 分支上强制 commit message 必须含任务号
  # 用于与项目管理系统（JIRA 等）集成
  task_id:
    enabled: true
    # 哪些分支需要任务号校验
    # 示例：feature/* 和 dev 分支
    branch_regex: "(?i)^refs/heads/(feature/|dev)(/|_|-|$)"
    # 任务号格式（正则）
    # 示例：[#TSK-001]、[#DEF-002] 等
    # 匹配规则：[#(TSK|DEF)-至少一个字符（不含方括号)]
    subject_regex: "\\[#(TSK|DEF)-[^\\[\\]]+\\]"
    # 只校验 commit subject（第一行）
    # true：仅校验 subject，不校验 body
    # false：校验整个 message
    check_subject_only: true
    # merge commit 是否豁免任务号校验
    exempt_merge_commit: true
    # 特殊 message 豁免正则
    # 命中此正则的 commit 会跳过任务号校验
    # 例如："^(Revert|auto:|ci:)" 表示 Revert / auto: / ci: 开头的可以豁免
    # 留空禁用
    exempt_message_regex: ""

# ─── 白名单（只豁免任务号校验，不豁免其他规则）─────────
# 白名单匹配的 commit 会跳过任务号校验
# 但仍需通过：强推校验、提交人一致性、受保护分支直接 push 等
whitelist:
  # 豁免任务号校验的用户（GL_USERNAME，大小写不敏感）
  users: []
  # 示例：
  # users:
  #   - "zhangsan"
  #   - "deploy-bot"
  #   - "ci-robot"

  # 豁免任务号校验的分支（正则匹配 ref 全名）
  # 示例：init/* 和 migrate/* 分支通常初始化，不需要任务号
  branch_regex: "(?i)^refs/heads/(init/|migrate/|tmp/)"

  # 豁免任务号校验的项目
  # 按 GL_PROJECT_PATH 最后一段（repo name）匹配
  # 示例：demo-service 项目可能是测试项目，不需要任务号
  projects:
    - "demo-service"
    - "legacy-repo"

# ─── 违规提示消息模板 ──────────────────────────────────
# 支持 Go text/template 语法和以下变量：
#   {{.ProjectPath}}    — 项目路径，如 group/my-repo
#   {{.RepoName}}       — 项目名称，如 my-repo
#   {{.Username}}       — GitLab 用户名
#   {{.BranchName}}     — 分支名（去掉 refs/heads/ 前缀）
#   {{.Protocol}}       — 操作协议（http/ssh/web）
#   {{.CommitID}}       — commit SHA（简短形式）
#   {{.CommitSubject}}  — commit 标题（第一行）
#   {{.CommitterEmail}} — commit committer 的 email
#
# 空字符串或不定义 = 使用代码内置默认模板
messages:
  language: "zh-CN"
  show_fix_guide: true
  templates:
    # ─── 禁止强制推送 ──
    non_fast_forward: |
      禁止强制推送（non fast-forward / rewrite history）

      project: {{.ProjectPath}}
      repo:    {{.RepoName}}
      user:    {{.Username}}
      branch:  {{.BranchName}}

      【如何处理】
      您的推送被拒绝，因为本地历史与远端不一致（可能是执行了 rebase 或 reset）。

      1) 拉取远端最新代码并将本地提交追加在后面：
         git pull --rebase origin {{.BranchName}}

      2) 如果出现冲突，解决冲突后继续：
         # 编辑冲突文件，解决后执行：
         git add <冲突文件>
         git rebase --continue

      3) 冲突全部解决后，正常推送：
         git push origin {{.BranchName}}

      注意：请勿使用 git push --force，这会覆盖其他人的提交。
      如您确认需要强制推送（例如整理个人开发分支），请联系管理员处理。

    # ─── 禁止直接 push 到受保护分支 ──
    direct_push_denied: |
      当前分支禁止直接 push，请通过 Merge Request 合并代码。

      【规范要求】
      该分支属于受保护分支，只允许通过 GitLab Merge Request 合并，
      不允许本地直接 git push。

      project:  {{.ProjectPath}}
      repo:     {{.RepoName}}
      user:     {{.Username}}
      branch:   {{.BranchName}}
      protocol: {{.Protocol}}

      【如何处理】
      1) 从目标分支创建新的功能分支：
         git checkout -b feature/<你的功能名> origin/{{.BranchName}}

      2) 在新分支上完成开发，然后推送功能分支：
         git push origin feature/<你的功能名>

      3) 登录 GitLab，发起 Merge Request，目标分支选择：
         {{.BranchName}}

      4) 等待审核通过后，由 GitLab 自动合并。

    # ─── 提交人与 push 用户不一致 ──
    committer_mismatch: |
      提交人信息不符合规范：commit 提交人与 push 用户不一致

      【规范要求】
      commit 的 committer 必须与当前 push 的 GitLab 用户一致。

      project:         {{.ProjectPath}}
      repo:            {{.RepoName}}
      push user:       {{.Username}}
      committer email: {{.CommitterEmail}}
      branch:          {{.BranchName}}
      commitid:        {{.CommitID}}

      【如何修改】
      请确认本地 Git 用户信息是否与 GitLab 用户一致：

      1) 查看当前本地 Git 用户配置：
         git config user.name
         git config user.email

      2) 将本地用户改为与 GitLab 一致：
         git config user.name "<GitLab用户名>"
         git config user.email "<GitLab用户名>@<公司域名>"

      3) 修正最近一次提交的 committer：
         git commit --amend --reset-author --no-edit

      4) 如需修改多次历史提交：
         git rebase -i HEAD~5
         # 将需要修改的 commit 标记为 edit，逐个执行：
         git commit --amend --reset-author --no-edit
         git rebase --continue

      5) 推送修正后的提交：
         git push --force-with-lease

    # ─── 缺少任务 ID ──
    task_id_missing: |
      提交信息不符合规范：缺少任务ID（[#TSK-...] 或 [#DEF-...]）

      【规范要求】commit subject 必须包含任务ID（二选一）
        [#TSK-xxx]  或  [#DEF-xxx]

      project:  {{.ProjectPath}}
      repo:     {{.RepoName}}
      user:     {{.Username}}
      branch:   {{.BranchName}}
      commitid: {{.CommitID}}
      commit:   {{.CommitSubject}}

      【如何修改】
      以下操作会重写提交历史，请先做好保护：
      1) 确认工作区干净：
         git status
      2) 创建备份分支（出错可恢复）：
         git branch backup/before-fix HEAD

      A) 只修改最近一次提交：
         git commit --amend -m "<原提交信息> [#TSK-xxx]"
         git push --force-with-lease

      B) 修改多次历史提交（rebase 方式）：
         方式1：修改最近 N 次提交（把 5 替换为实际数量）
         git rebase -i HEAD~5
         # 将需要修改的行从 pick 改为 reword，保存后按提示逐个修改

         方式2：从分叉点开始（推荐，不用数数量）
         base=$(git merge-base origin/{{.BranchName}} HEAD)
         git rebase -i "$base"

         完成后推送：
         git push --force-with-lease

logging:
  level: "info"
  stderr: true
