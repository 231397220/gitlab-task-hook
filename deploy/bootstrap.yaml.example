# gitlab-task-hook bootstrap 配置示例
#
# 此文件用于 config-sync 模式，指定 Nacos 连接信息和本地缓存路径。
# hook 模式执行时不读取此文件。
#
# 部署时：
# 1. 复制此文件为 /etc/gitlab-task-hook/bootstrap.yaml
# 2. 根据实际环境修改 Nacos 连接信息
# 3. 设置文件权限为 600（避免密码泄露）：chmod 600 /etc/gitlab-task-hook/bootstrap.yaml

nacos:
  # 是否启用 Nacos 同步
  enabled: true

  # Nacos server 地址，包括协议和端口
  # 示例：http://127.0.0.1:8848 或 http://nacos.example.com:8848
  server_addr: "http://127.0.0.1:8848"

  # Nacos 命名空间 ID
  # 如果使用默认 public 命名空间，留空或填 ""
  # 如果使用 dev 命名空间，填 "dev"
  namespace_id: "dev"

  # Nacos group（必填，由 Nacos 管理员定义）
  # 当前固定值
  group: "GITLAB_HOOK"

  # Nacos dataId（必填，由 Nacos 管理员定义）
  # 当前固定值
  data_id: "gitlab-task-hook.yaml"

  # Nacos 用户名（若 Nacos 启用了认证）
  # 示例：nacos
  username: "nacos"

  # Nacos 密码（若 Nacos 启用了认证）
  # 注意：此文件应设置为 600 权限，避免泄露
  # 示例：nacos
  password: "nacos"

  # AK/SK 认证（可选，若 Nacos 使用 AK/SK 鉴权）
  access_key: ""
  secret_key: ""

  # HTTP 超时时间（秒）
  timeout_seconds: 5

  # 是否启用配置监听（watch）
  # true：config-sync 监听 Nacos 配置变化，变化后自动更新
  # false：依赖定时轮询，性能略差但更稳定
  watch_enabled: true

  # 轮询间隔（秒）
  # 当 watch 不可用时使用轮询
  # 建议值：30（平衡实时性和 Nacos 压力）
  poll_interval_seconds: 30

  # 本地缓存文件路径（必填）
  # hook 模式读取此文件
  # 应设置为 git 用户可读的位置
  cache_file: "/var/opt/gitlab/gitaly/custom_hooks/config/gitlab-task-hook.yaml"

  # 缓存元数据文件路径（可选）
  # 记录上次同步时间、MD5 等信息
  cache_meta_file: "/var/opt/gitlab/gitaly/custom_hooks/config/gitlab-task-hook.yaml.meta"

  # config-sync 日志文件路径（可选）
  # 若不指定，日志输出到 stderr（由 systemd 捕获）
  log_file: "/var/log/gitlab-task-hook/config-sync.log"

  # 文件锁路径（用于防止并发）
  lock_file: "/var/opt/gitlab/gitaly/custom_hooks/config/gitlab-task-hook.lock"
